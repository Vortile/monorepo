# Environment Variables for Server

# Node Environment
NODE_ENV=development
PORT=3000

# ============================================
# Database (Supabase)
# ============================================
# Get both strings from: Supabase Dashboard → Project Settings → Database → Connection string
#
# Transaction pooler (port 6543) — used by the app at runtime on Vercel
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#
# Direct connection (port 5432) — used by drizzle-kit for push/migrate (do NOT use pooler for migrations)
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
EMAIL_FROM=noreply@vortile.io

# Admin Dashboard Origin (for CORS)
ADMIN_ORIGIN=http://localhost:3001

# ============================================
# Gupshup Partner API Configuration
# ============================================

# Gupshup Partner Credentials
# Get these from: https://partner.gupshup.io

# Your Tech Provider/Partner ID from Gupshup
GUPSHUP_PARTNER_ID=your_partner_id_here

# JWT Partner Token from Gupshup Partner Portal
# Navigate to: Settings → API Tokens in Partner Portal
GUPSHUP_PARTNER_TOKEN=your_jwt_partner_token_here

# Gupshup Partner API Base URL (usually don't change this)
GUPSHUP_PARTNER_API_URL=https://partner.gupshup.io

# Webhook Verification Token
# Create a random secure string for webhook verification
# Generate: openssl rand -hex 32
GUPSHUP_WEBHOOK_VERIFY_TOKEN=your_secure_random_token_here

# ============================================
# How to Set Up Gupshup Partner Account
# ============================================
#
# 1. Sign Up as Tech Provider:
#    - Go to https://partner.gupshup.io
#    - Register as a Tech Provider/ISV
#    - Complete business verification
#
# 2. Get Partner ID:
#    - After registration, your Partner ID appears in dashboard
#
# 3. Generate Partner Token:
#    - Log in to Partner Portal
#    - Navigate to Settings → API Tokens
#    - Click "Generate Token" or copy existing JWT token
#    - This token authenticates all API requests
#    - Store securely - it's like a password!
#
# 4. Set Webhook Verification Token:
#    - Generate random string: openssl rand -hex 32
#    - Add to GUPSHUP_WEBHOOK_VERIFY_TOKEN above
#    - Configure same token in Partner Portal webhook settings
#
# 5. Onboarding Flow:
#    - Merchants onboard through Gupshup's embedded signup UI
#    - You get appId and appName after onboarding
#    - Register via: POST /waba/onboarding/register
#    - See docs/GUPSHUP_WABA_ONBOARDING.md for details
#
# ============================================
# Ngrok for Local Development
# ============================================
#
# For local webhook testing:
# 1. Install ngrok: npm install -g ngrok
# 2. Run: ngrok http 3000
# 3. Copy the HTTPS URL (e.g., https://abc123.ngrok.io)
# 4. Use as webhook URL in Gupshup Portal: https://abc123.ngrok.io/waba/webhook
#
# ============================================
