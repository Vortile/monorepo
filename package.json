{
  "name": "vortile-delivery-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "build:api": "turbo --filter api build",
    "build:admin": "turbo --filter admin build",
    "build:merchant": "turbo --filter merchant build",
    "build:storefront": "turbo --filter storefront build",
    "dev": "turbo dev",
    "dev:api": "turbo dev --filter=api",
    "dev:email": "turbo dev --filter=email",
    "dev:admin": "turbo dev --filter=admin",
    "dev:merchant": "turbo dev --filter=merchant",
    "dev:storefront": "turbo dev --filter=storefront",
    "start": "pnpm -r --parallel start",
    "i": "pnpm -r i",
    "preinstall": "npx only-allow pnpm",
    "clean": "pnpm -r --parallel exec rm -rf node_modules && rm -rf node_modules",
    "lint": "eslint .",
    "db:generate": "pnpm --filter @vortile/database generate",
    "db:push": "pnpm --filter @vortile/database push"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@babel/eslint-parser": "^7.28.0",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^9.39.1",
    "@next/eslint-plugin-next": "^15.4.1",
    "@typescript-eslint/eslint-plugin": "^8.39.1",
    "@typescript-eslint/parser": "^8.39.1",
    "eslint": "^9.31.0",
    "eslint-config-next": "16.0.3",
    "eslint-config-prettier": "^10.1.5",
    "eslint-config-turbo": "^2.6.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "@types/node": "20.9.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "globals": "^16.5.0",
    "turbo": "^2.6.1",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.37.0"
  },
  "packageManager": "pnpm@10.11.0"
}
